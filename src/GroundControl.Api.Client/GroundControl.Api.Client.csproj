<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <NoWarn>$(NoWarn);CA2007;CS1591;CA1822</NoWarn>
        <NSwagConfigFile>$(MSBuildProjectDirectory)\nswag.json</NSwagConfigFile>
        <GenerateApiClient>true</GenerateApiClient>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.Extensions.Http" />
        <PackageReference Include="NSwag.MSBuild" PrivateAssets="all" />
    </ItemGroup>

    <!-- Suppress code analysis on Kiota-generated files -->
    <ItemGroup>
        <Compile Update="Generated\**\*.cs">
            <ExcludeFromCodeAnalysis>true</ExcludeFromCodeAnalysis>
        </Compile>
    </ItemGroup>

    <Target Name="GenerateApiClient" BeforeTargets="CoreCompile"
            Condition="'$(GenerateApiClient)' == 'true'">
        <Exec Command="$(NSwagExe_Net100) run $(NSwagConfigFile)" WorkingDirectory="$(MSBuildProjectDirectory)" />
    </Target>

</Project>
