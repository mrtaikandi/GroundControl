{
  "$schema": "https://tr.designtokens.org/format/",
  "$description": "Design tokens for GroundControl (The Tower). Framework-agnostic. Re-emit into Tailwind config, CSS variables, iOS color sets, Android resources, etc. Light + dark values provided as sibling modes.",

  "color": {
    "neutral": {
      "white":    { "$value": { "light": "#ffffff", "dark": "#2d2d30" }, "$description": "Raised surfaces: cards, drawers, inputs." },
      "50":       { "$value": { "light": "#fbfbfc", "dark": "#2d2d30" }, "$description": "Page / sidebar background." },
      "100":      { "$value": { "light": "#eceaf0", "dark": "#333337" }, "$description": "Hairline fills, hover states." },
      "200":      { "$value": { "light": "#dfdde6", "dark": "#3c3c40" }, "$description": "Dividers." },
      "300":      { "$value": { "light": "#d1d0d8", "dark": "#48484d" }, "$description": "Field borders." },
      "400":      { "$value": { "light": "#a5a3b0", "dark": "#6e6e73" }, "$description": "Subtle icons." },
      "500":      { "$value": { "light": "#74727f", "dark": "#9d9da3" }, "$description": "Captions, placeholders." },
      "600":      { "$value": { "light": "#55535e", "dark": "#bcbcc0" } },
      "700":      { "$value": { "light": "#3c3a44", "dark": "#d4d4d6" }, "$description": "Body text." },
      "800":      { "$value": { "light": "#27262d", "dark": "#e4e4e6" } },
      "900":      { "$value": { "light": "#16151a", "dark": "#f2f2f3" }, "$description": "Headings." },
      "950":      { "$value": { "light": "#0a090c", "dark": "#fafafa" } }
    },

    "accent": {
      "$description": "Violet / indigo-purple. Primary brand accent.",
      "50":   { "$value": { "light": "#f4f1fb", "dark": "rgba(110, 74, 216, 0.14)" } },
      "100":  { "$value": { "light": "#e7e1f6", "dark": "rgba(110, 74, 216, 0.22)" } },
      "200":  { "$value": { "light": "#cdc1ee", "dark": "rgba(110, 74, 216, 0.36)" } },
      "600":  { "$value": { "light": "#6e4ad8", "dark": "#8e6eff" }, "$description": "Primary buttons, focus rings, active rails." },
      "700":  { "$value": { "light": "#5a39bc", "dark": "#a48cff" }, "$description": "Hover on primary." },
      "800":  { "$value": { "light": "#452a92", "dark": "#c9b8ff" }, "$description": "Text on soft-accent surfaces." }
    },

    "success": {
      "50":  { "$value": { "light": "#eaf3e8", "dark": "rgba(79, 184, 72, 0.16)" } },
      "100": { "$value": { "light": "#cee6c9", "dark": "rgba(79, 184, 72, 0.24)" } },
      "500": { "$value": { "light": "#4fb848", "dark": "#4fb848" }, "$description": "Live/OK dots." },
      "800": { "$value": { "light": "#1f561d", "dark": "#9ed79a" } }
    },
    "warning": {
      "50":  { "$value": { "light": "#fbf5e4", "dark": "rgba(212, 177, 58, 0.18)" } },
      "500": { "$value": { "light": "#c29523", "dark": "#d4b13a" } },
      "800": { "$value": { "light": "#5a430a", "dark": "#e8cf7d" } }
    },
    "critical": {
      "50":  { "$value": { "light": "#fbe9e6", "dark": "rgba(201, 72, 58, 0.18)" } },
      "600": { "$value": { "light": "#c9483a", "dark": "#c9483a" } },
      "700": { "$value": { "light": "#a53929", "dark": "#eaa098" } }
    }
  },

  "semantic": {
    "$description": "Role-based tokens. Consume THESE in components, not raw palette values. They're the contract between design and code.",

    "bg": {
      "page":           { "$value": "{color.neutral.50}" },
      "container":      { "$value": { "light": "#f5f4f8", "dark": "#252526" }, "$description": "Slightly inset surface behind cards." },
      "surface":        { "$value": "{color.neutral.white}", "$description": "Cards, drawers, inputs." },
      "selected":       { "$value": { "light": "#f4f1fb", "dark": "rgba(110, 74, 216, 0.18)" }, "$description": "Selected row in a list." },
      "selectedStrong": { "$value": { "light": "#e7e1f6", "dark": "rgba(110, 74, 216, 0.28)" } },
      "chipSelected":   { "$value": { "light": "#16151a", "dark": "#f2f2f3" }, "$description": "Active filter chip (inverse of its mode)." }
    },

    "fg": {
      "heading":       { "$value": "{color.neutral.900}" },
      "body":          { "$value": "{color.neutral.700}" },
      "caption":       { "$value": "{color.neutral.500}" },
      "link":          { "$value": "{color.accent.700}" },
      "iconSubtle":    { "$value": "{color.neutral.400}" },
      "onSelected":    { "$value": "{color.accent.800}", "$description": "Text on bg.selected." },
      "chipSelected":  { "$value": { "light": "#ffffff", "dark": "#16151a" }, "$description": "Text on bg.chipSelected." }
    },

    "stroke": {
      "divider":       { "$value": "{color.neutral.200}" },
      "subtle":        { "$value": "{color.neutral.100}" },
      "fieldInitial":  { "$value": "{color.neutral.300}" },
      "fieldFocus":    { "$value": "{color.accent.600}" }
    },

    "badge": {
      "neutral":  { "bg": { "$value": "{color.neutral.100}" }, "fg": { "$value": "{color.neutral.700}" } },
      "info":     { "bg": { "$value": "{color.accent.50}" },   "fg": { "$value": "{color.accent.800}" } },
      "success":  { "bg": { "$value": "{color.success.50}" },  "fg": { "$value": "{color.success.800}" } },
      "warning":  { "bg": { "$value": "{color.warning.50}" },  "fg": { "$value": "{color.warning.800}" } },
      "critical": { "bg": { "$value": "{color.critical.50}" }, "fg": { "$value": "{color.critical.700}" } }
    },

    "syntax": {
      "$description": "JSON / code-view syntax tokens. Applied in Configuration's JSON mode and the Snapshots JSON doc + JSON diff views. Values retint per-mode so the palette stays legible on both the light neutral-100 background and the dark container surface.",
      "key":         { "$value": { "light": "{color.accent.700}",   "dark": "#9cdcfe" }, "$description": "Property names (object keys)." },
      "string":      { "$value": { "light": "{color.success.800}",  "dark": "#ce9178" }, "$description": "String literal values." },
      "number":      { "$value": { "light": "{color.critical.700}", "dark": "#b5cea8" }, "$description": "Numeric & boolean literals." },
      "punct":       { "$value": { "light": "{color.neutral.500}",  "dark": "#808080" }, "$description": "Braces, colons, commas." },
      "sensitive":   { "$value": { "light": "{color.warning.800}",  "dark": "#dcdcaa" }, "$description": "Masked (••••••••) sensitive value text." },
      "sensitiveBg": { "$value": { "light": "{color.warning.50}",   "dark": "rgba(220, 220, 170, 0.14)" }, "$description": "Tint behind the trailing 'sensitive' marker pill on a masked JSON line." },
      "diffAddBg":   { "$value": { "light": "rgba(79, 184, 72, 0.14)",  "dark": "rgba(79, 184, 72, 0.22)" }, "$description": "Line background for additions in diff views." },
      "diffAddFg":   { "$value": { "light": "{color.success.800}",  "dark": "#9ed79a" } },
      "diffDelBg":   { "$value": { "light": "rgba(221, 92, 76, 0.10)",  "dark": "rgba(221, 92, 76, 0.22)" }, "$description": "Line background for deletions in diff views." },
      "diffDelFg":   { "$value": { "light": "{color.critical.700}", "dark": "#eaa098" } }
    },

    "overlay": {
      "scrim": { "$value": { "light": "rgba(22, 21, 26, 0.35)", "dark": "rgba(22, 21, 26, 0.35)" }, "$description": "Modal and drawer backdrop overlay." }
    },

    "shadow": {
      "button":        { "$value": { "light": "0 1px 2px rgba(0, 0, 40, 0.16)", "dark": "0 1px 2px rgba(0, 0, 40, 0.16)" }, "$description": "Primary button elevation." },
      "buttonDanger":  { "$value": { "light": "0 1px 2px rgba(0, 0, 40, 0.12)", "dark": "0 1px 2px rgba(0, 0, 40, 0.12)" }, "$description": "Destructive button elevation." },
      "buttonSubtle":  { "$value": { "light": "0 1px 2px rgba(0, 0, 40, 0.06)", "dark": "0 1px 2px rgba(0, 0, 40, 0.06)" }, "$description": "Secondary button elevation." },
      "floating":      { "$value": "{shadow.floating}", "$description": "Floating panels such as popovers, menus, and selects." },
      "modal":         { "$value": "{shadow.modal}", "$description": "Dialogs and sheets." }
    },

    "interaction": {
      "button": {
        "activeBrightness": { "$value": { "light": "0.97", "dark": "0.97" }, "$description": "Pressed-state brightness for primary buttons." },
        "hoverBrightness":  { "$value": { "light": "1.04", "dark": "1.04" }, "$description": "Hover brightness for primary buttons." }
      },
      "buttonDanger": {
        "activeBrightness": { "$value": { "light": "0.96", "dark": "0.96" }, "$description": "Pressed-state brightness for destructive buttons." },
        "hoverBrightness":  { "$value": { "light": "1.03", "dark": "1.03" }, "$description": "Hover brightness for destructive buttons." }
      }
    }
  },

  "typography": {
    "fontFamily": {
      "title":  { "$value": "Inter, 'Segoe UI Variable', 'Segoe UI', -apple-system, system-ui, sans-serif" },
      "body":   { "$value": "Inter, 'Segoe UI Variable', 'Segoe UI', -apple-system, system-ui, sans-serif" },
      "code":   { "$value": "'Cascadia Code', 'Cascadia Mono', Consolas, 'SF Mono', ui-monospace, Menlo, monospace", "$description": "Used for every machine-identifier: keys, project IDs, scope dimensions, audit entityType/action, endpoints." }
    },
    "scale": {
      "pageTitle":    { "fontSize": "34px", "lineHeight": 1.1,  "fontWeight": 700, "letterSpacing": "-0.025em", "family": "title" },
      "sectionTitle": { "fontSize": "19px", "lineHeight": 1.2,  "fontWeight": 700, "letterSpacing": "-0.015em", "family": "title" },
      "modalTitle":   { "fontSize": "22px", "lineHeight": 1.2,  "fontWeight": 500, "letterSpacing": "-0.015em", "family": "title" },
      "bodyLg":       { "fontSize": "14.5px", "lineHeight": 1.5, "fontWeight": 400, "family": "body" },
      "body":         { "fontSize": "13px",   "lineHeight": 1.5, "fontWeight": 400, "family": "body" },
      "bodySm":       { "fontSize": "12.5px", "lineHeight": 1.5, "fontWeight": 400, "family": "body" },
      "caption":      { "fontSize": "11.5px", "lineHeight": 1.4, "fontWeight": 400, "family": "body", "color": "fg.caption" },
      "eyebrow":      { "fontSize": "11px",   "lineHeight": 1.4, "fontWeight": 500, "family": "body", "letterSpacing": "0.08em", "textTransform": "uppercase", "color": "fg.caption" },
      "code":         { "fontSize": "12.5px", "lineHeight": 1.5, "fontWeight": 400, "family": "code" }
    }
  },

  "spacing": {
    "$description": "Used as padding/margin. Multiples of 4 generally; header & section chrome uses a different scale (36/56) for editorial rhythm.",
    "0":   { "$value": "0" },
    "1":   { "$value": "4px" },
    "2":   { "$value": "8px" },
    "3":   { "$value": "12px" },
    "4":   { "$value": "16px" },
    "5":   { "$value": "20px" },
    "6":   { "$value": "24px" },
    "8":   { "$value": "32px" },
    "9":   { "$value": "36px", "$description": "Page head vertical padding." },
    "14":  { "$value": "56px", "$description": "Page head horizontal padding." }
  },

  "radius": {
    "sm":   { "$value": "3px",  "$description": "Inline code chips, scope badges." },
    "md":   { "$value": "4px",  "$description": "Pills, small buttons, small badges." },
    "lg":   { "$value": "6px",  "$description": "Inputs, nav items, secondary buttons." },
    "xl":   { "$value": "8px",  "$description": "Cards, table containers." },
    "2xl":  { "$value": "10px", "$description": "Modal surfaces, floating panels." },
    "pill": { "$value": "9999px", "$description": "Primary/secondary buttons (fully rounded)." }
  },

  "shadow": {
    "floating":  { "$value": "0 18px 40px -16px rgba(0, 0, 40, 0.25)", "$description": "Tweaks panel, dropdowns." },
    "modal":     { "$value": "0 30px 70px -20px rgba(0, 0, 40, 0.45)", "$description": "Publish snapshot modal." }
  },

  "layout": {
    "sidebarWidth": { "$value": "232px" },
    "headerHeight": { "$value": "56px" },
    "pageMaxWidth": { "$value": "1280px" },
    "configPanelWidth": { "$value": "460px", "$description": "Right-side detail panel on Configuration." }
  },

  "motion": {
    "pulse": { "$value": { "duration": "1.8s", "timing": "ease-out", "iteration": "infinite", "transform": "scale(1) → scale(2.4)", "opacity": "0.55 → 0" }, "$description": "Live/activity dots." },
    "hover": { "$value": { "duration": "120ms", "timing": "ease" }, "$description": "Button background transitions." }
  }
}
