{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "dotnet \".claude/hooks/format-csharp.cs\"",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "additionalDirectories": [
    ".claude/worktrees/",
    ".claude/worktrees/**"
  ]
}